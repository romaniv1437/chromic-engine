[{"time": 33.62, "text": "Краплёные карты, двойные стандарты", "words": [{"word": "Краплёные", "start": 33.62, "end": 34.38}, {"word": "карты,", "start": 34.39, "end": 34.88}, {"word": "двойные", "start": 35.12, "end": 35.52}, {"word": "стандарты", "start": 35.53, "end": 36.26}]}, {"time": 36.42, "text": "Тузы щеголяют на казённые бабки", "words": [{"word": "Тузы", "start": 36.42, "end": 36.76}, {"word": "щеголяют", "start": 36.77, "end": 37.58}, {"word": "на", "start": 37.59, "end": 37.63}, {"word": "казённые", "start": 37.64, "end": 38.4}, {"word": "бабки", "start": 38.41, "end": 39.04}]}, {"time": 39.22, "text": "В духовном упадке живётся несладко", "words": [{"word": "В", "start": 39.22, "end": 39.26}, {"word": "духовном", "start": 39.27, "end": 39.8}, {"word": "упадке", "start": 39.81, "end": 40.5}, {"word": "живётся", "start": 40.51, "end": 41.0}, {"word": "несладко", "start": 41.01, "end": 41.68}]}, {"time": 41.78, "text": "Нищета в голове, как консервная банка", "words": [{"word": "Нищета", "start": 41.78, "end": 42.26}, {"word": "в", "start": 42.27, "end": 42.46}, {"word": "голове,", "start": 42.47, "end": 43.08}, {"word": "как", "start": 43.18, "end": 43.28}, {"word": "консервная", "start": 43.29, "end": 43.94}, {"word": "банка", "start": 43.95, "end": 44.42}]}, {"time": 44.56, "text": "Там, где на полустанках, стоят куртизанки", "words": [{"word": "Там,", "start": 44.56, "end": 44.72}, {"word": "где", "start": 44.86, "end": 44.88}, {"word": "на", "start": 44.89, "end": 45.12}, {"word": "полустанках,", "start": 45.13, "end": 45.9}, {"word": "стоят", "start": 45.91, "end": 46.48}, {"word": "куртизанки", "start": 46.49, "end": 47.32}]}, {"time": 47.56, "text": "Рясы напялили бывшие панки", "words": [{"word": "Рясы", "start": 47.56, "end": 48.02}, {"word": "напялили", "start": 48.03, "end": 48.94}, {"word": "бывшие", "start": 48.95, "end": 49.54}, {"word": "панки", "start": 49.55, "end": 49.9}]}, {"time": 50.02, "text": "Там, где водку бухают, заедая буханкой", "words": [{"word": "Там,", "start": 50.02, "end": 50.16}, {"word": "где", "start": 50.17, "end": 50.36}, {"word": "водку", "start": 50.37, "end": 50.68}, {"word": "бухают,", "start": 50.69, "end": 51.32}, {"word": "заедая", "start": 51.56, "end": 52.08}, {"word": "буханкой", "start": 52.09, "end": 52.64}]}, {"time": 52.65, "text": "Белые не растут, в основном лишь поганки", "words": [{"word": "Белые", "start": 52.65, "end": 53.26}, {"word": "не", "start": 53.27, "end": 53.5}, {"word": "растут,", "start": 53.51, "end": 54.06}, {"word": "в", "start": 54.34, "end": 54.34}, {"word": "основном", "start": 54.35, "end": 54.7}, {"word": "лишь", "start": 54.71, "end": 54.88}, {"word": "поганки", "start": 54.89, "end": 55.52}]}, {"time": 55.53, "text": "Эти странные игры нувориш аппер-класса", "words": [{"word": "Эти", "start": 55.53, "end": 55.92}, {"word": "странные", "start": 55.93, "end": 56.46}, {"word": "игры", "start": 56.47, "end": 56.76}, {"word": "нувориш", "start": 56.77, "end": 57.44}, {"word": "аппер-класса", "start": 57.62, "end": 58.32}]}, {"time": 58.33, "text": "Для них люди не люди, для них люди лишь мясо", "words": [{"word": "Для", "start": 58.33, "end": 58.44}, {"word": "них", "start": 58.45, "end": 58.68}, {"word": "люди", "start": 58.69, "end": 58.94}, {"word": "не", "start": 58.95, "end": 59.2}, {"word": "люди,", "start": 59.21, "end": 59.573}, {"word": "для", "start": 59.583, "end": 59.797}, {"word": "них", "start": 59.807, "end": 60.021}, {"word": "люди", "start": 60.031, "end": 60.32}, {"word": "лишь", "start": 60.33, "end": 60.56}, {"word": "мясо", "start": 60.57, "end": 60.61}]}, {"time": 60.62, "text": "Мясо делает кассу, мясо для них лишь масса", "words": [{"word": "Мясо", "start": 60.62, "end": 61.04}, {"word": "делает", "start": 61.46, "end": 61.82}, {"word": "кассу,", "start": 61.83, "end": 62.34}, {"word": "мясо", "start": 62.35, "end": 62.614}, {"word": "для", "start": 62.624, "end": 62.82}, {"word": "них", "start": 62.83, "end": 63.026}, {"word": "лишь", "start": 63.036, "end": 63.3}, {"word": "масса", "start": 63.31, "end": 63.62}]}, {"time": 63.63, "text": "Но, если есть мозг у мяса, значит, мясо опасно", "words": [{"word": "Но,", "start": 63.63, "end": 63.78}, {"word": "если", "start": 63.79, "end": 64.12}, {"word": "есть", "start": 64.13, "end": 64.36}, {"word": "мозг", "start": 64.37, "end": 64.66}, {"word": "у", "start": 64.76, "end": 64.94}, {"word": "мяса,", "start": 64.95, "end": 65.28}, {"word": "значит,", "start": 65.29, "end": 65.46}, {"word": "мясо", "start": 65.47, "end": 66.0}, {"word": "опасно", "start": 66.01, "end": 66.58}]}, {"time": 66.68, "text": "Вот поэтому СМИ кормят нас комбикормом", "words": [{"word": "Вот", "start": 66.68, "end": 67.17}, {"word": "поэтому", "start": 67.18, "end": 67.38}, {"word": "СМИ", "start": 67.39, "end": 67.86}, {"word": "кормят", "start": 67.87, "end": 68.36}, {"word": "нас", "start": 68.37, "end": 68.5}, {"word": "комбикормом", "start": 68.51, "end": 69.32}]}, {"time": 69.33, "text": "Смесь госпропаганды и дешёвого порно", "words": [{"word": "Смесь", "start": 69.33, "end": 69.62}, {"word": "госпропаганды", "start": 69.63, "end": 70.66}, {"word": "и", "start": 70.67, "end": 70.92}, {"word": "дешёвого", "start": 70.93, "end": 71.58}, {"word": "порно", "start": 71.59, "end": 71.96}]}, {"time": 71.97, "text": "Смесь Лепса с Биланом под биты Вани Дорна", "words": [{"word": "Смесь", "start": 71.97, "end": 72.38}, {"word": "Лепса", "start": 72.39, "end": 72.74}, {"word": "с", "start": 72.75, "end": 72.84}, {"word": "Биланом", "start": 72.85, "end": 73.24}, {"word": "под", "start": 73.6, "end": 73.96}, {"word": "биты", "start": 73.97, "end": 74.01}, {"word": "Вани", "start": 74.02, "end": 74.78}, {"word": "Дорна", "start": 74.79, "end": 74.83}]}, {"time": 74.84, "text": "Этим стрёмным попкорном мы сыты по горло", "words": [{"word": "Этим", "start": 74.84, "end": 75.1}, {"word": "стрёмным", "start": 75.11, "end": 75.56}, {"word": "попкорном", "start": 75.57, "end": 76.22}, {"word": "мы", "start": 76.23, "end": 76.58}, {"word": "сыты", "start": 76.59, "end": 76.98}, {"word": "по", "start": 76.99, "end": 77.18}, {"word": "горло", "start": 77.19, "end": 77.54}]}, {"time": 77.55, "text": "Хватит пичкать нас фразами, типа «вы вне формата»", "words": [{"word": "Хватит", "start": 77.55, "end": 77.94}, {"word": "пичкать", "start": 77.95, "end": 78.3}, {"word": "нас", "start": 78.31, "end": 78.44}, {"word": "фразами,", "start": 78.45, "end": 78.98}, {"word": "типа", "start": 79.02, "end": 79.24}, {"word": "«вы", "start": 79.25, "end": 79.42}, {"word": "вне", "start": 79.43, "end": 79.66}, {"word": "формата»", "start": 79.67, "end": 80.28}]}, {"time": 80.29, "text": "Вкусовщина барыг с всероссийским охватом", "words": [{"word": "Вкусовщина", "start": 80.29, "end": 81.16}, {"word": "барыг", "start": 81.17, "end": 81.7}, {"word": "с", "start": 81.82, "end": 81.98}, {"word": "всероссийским", "start": 81.99, "end": 82.46}, {"word": "охватом", "start": 82.47, "end": 83.1}]}, {"time": 83.11, "text": "Поглотила умы тех, кто в креслах по блату", "words": [{"word": "Поглотила", "start": 83.11, "end": 83.82}, {"word": "умы", "start": 83.83, "end": 84.34}, {"word": "тех,", "start": 84.44, "end": 84.58}, {"word": "кто", "start": 84.82, "end": 84.82}, {"word": "в", "start": 85.14, "end": 85.24}, {"word": "креслах", "start": 85.25, "end": 85.35}, {"word": "по", "start": 85.36, "end": 85.44}, {"word": "блату", "start": 85.45, "end": 85.49}]}, {"time": 85.5, "text": "В тренде те, кто поёт оды для супостатов", "words": [{"word": "В", "start": 85.5, "end": 85.6}, {"word": "тренде", "start": 85.9, "end": 86.2}, {"word": "те,", "start": 86.21, "end": 86.36}, {"word": "кто", "start": 86.37, "end": 86.52}, {"word": "поёт", "start": 86.53, "end": 87.16}, {"word": "оды", "start": 87.17, "end": 87.54}, {"word": "для", "start": 87.55, "end": 87.8}, {"word": "супостатов", "start": 87.81, "end": 88.7}]}, {"time": 88.71, "text": "Мысли глубоко, пока есть смысл", "words": [{"word": "Мысли", "start": 88.71, "end": 89.28}, {"word": "глубоко,", "start": 89.29, "end": 90.02}, {"word": "пока", "start": 90.22, "end": 90.34}, {"word": "есть", "start": 90.35, "end": 90.7}, {"word": "смысл", "start": 90.71, "end": 91.6}]}, {"time": 91.61, "text": "Ищи среди слов, ищи среди чисел", "words": [{"word": "Ищи", "start": 91.61, "end": 92.12}, {"word": "среди", "start": 92.13, "end": 92.48}, {"word": "слов,", "start": 92.49, "end": 92.78}, {"word": "ищи", "start": 92.79, "end": 93.035}, {"word": "среди", "start": 93.045, "end": 93.46}, {"word": "чисел", "start": 93.47, "end": 93.98}]}, {"time": 93.99, "text": "Что, если реальность и есть вымысел", "words": [{"word": "Что,", "start": 93.99, "end": 94.7}, {"word": "если", "start": 94.71, "end": 94.9}, {"word": "реальность", "start": 94.91, "end": 95.92}, {"word": "и", "start": 95.93, "end": 95.97}, {"word": "есть", "start": 95.98, "end": 96.22}, {"word": "вымысел", "start": 96.23, "end": 97.18}]}, {"time": 97.28, "text": "С запахом свинца примесью", "words": [{"word": "С", "start": 97.28, "end": 97.38}, {"word": "запахом", "start": 97.39, "end": 97.92}, {"word": "свинца", "start": 97.93, "end": 98.6}, {"word": "примесью", "start": 98.61, "end": 99.8}]}, {"time": 99.81, "text": "Выльется вода полностью", "words": [{"word": "Выльется", "start": 99.81, "end": 100.54}, {"word": "вода", "start": 100.72, "end": 101.42}, {"word": "полностью", "start": 101.43, "end": 102.1}]}, {"time": 102.51, "text": "Вот тогда пойдёт слух по лесу", "words": [{"word": "Вот", "start": 102.51, "end": 103.0}, {"word": "тогда", "start": 103.01, "end": 103.32}, {"word": "пойдёт", "start": 103.33, "end": 103.82}, {"word": "слух", "start": 103.83, "end": 104.24}, {"word": "по", "start": 104.25, "end": 104.34}, {"word": "лесу", "start": 104.35, "end": 104.98}]}, {"time": 104.99, "text": "А когда война кончится", "words": [{"word": "А", "start": 104.99, "end": 105.74}, {"word": "когда", "start": 105.75, "end": 106.06}, {"word": "война", "start": 106.07, "end": 106.88}, {"word": "кончится", "start": 106.89, "end": 107.88}]}, {"time": 108.44, "text": "Вам мои слова вспомнятся", "words": [{"word": "Вам", "start": 108.44, "end": 108.64}, {"word": "мои", "start": 108.65, "end": 108.8}, {"word": "слова", "start": 108.81, "end": 109.36}, {"word": "вспомнятся", "start": 109.37, "end": 110.4}]}, {"time": 110.41, "text": "Лезгинка на столе в курточке Армани", "words": [{"word": "Лезгинка", "start": 110.41, "end": 111.12}, {"word": "на", "start": 111.13, "end": 111.34}, {"word": "столе", "start": 111.35, "end": 111.7}, {"word": "в", "start": 111.71, "end": 111.84}, {"word": "курточке", "start": 111.85, "end": 112.3}, {"word": "Армани", "start": 112.31, "end": 112.96}]}, {"time": 112.97, "text": "Тупые бэк-эмси продались с потрохами", "words": [{"word": "Тупые", "start": 112.97, "end": 113.74}, {"word": "бэк-эмси", "start": 113.75, "end": 114.4}, {"word": "продались", "start": 114.41, "end": 114.8}, {"word": "с", "start": 114.9, "end": 115.0}, {"word": "потрохами", "start": 115.01, "end": 115.64}]}, {"time": 115.65, "text": "Нашла коса на камень, общество на грани", "words": [{"word": "Нашла", "start": 115.65, "end": 116.46}, {"word": "коса", "start": 116.47, "end": 116.84}, {"word": "на", "start": 116.85, "end": 117.04}, {"word": "камень,", "start": 117.05, "end": 117.42}, {"word": "общество", "start": 117.7, "end": 118.14}, {"word": "на", "start": 118.15, "end": 118.4}, {"word": "грани", "start": 118.41, "end": 118.76}]}, {"time": 118.77, "text": "Госпропаганда льёт нам в уши тонны несусветной дряни", "words": [{"word": "Госпропаганда", "start": 118.77, "end": 119.66}, {"word": "льёт", "start": 119.67, "end": 119.84}, {"word": "нам", "start": 119.85, "end": 120.06}, {"word": "в", "start": 120.16, "end": 120.26}, {"word": "уши", "start": 120.27, "end": 120.44}, {"word": "тонны", "start": 120.45, "end": 120.68}, {"word": "несусветной", "start": 120.69, "end": 121.42}, {"word": "дряни", "start": 121.43, "end": 121.76}]}, {"time": 121.77, "text": "Система, крыса — это ты", "words": [{"word": "Система,", "start": 121.77, "end": 122.46}, {"word": "крыса", "start": 122.47, "end": 122.78}, {"word": "—", "start": 122.79, "end": 122.83}, {"word": "это", "start": 122.84, "end": 123.1}, {"word": "ты", "start": 123.11, "end": 123.21}]}, {"time": 124.93, "text": "И те, кто в кровь стирают кошельки, ради лживой правды", "words": [{"word": "И", "start": 124.93, "end": 125.19}, {"word": "те,", "start": 125.2, "end": 125.37}, {"word": "кто", "start": 125.38, "end": 125.53}, {"word": "в", "start": 125.54, "end": 125.63}, {"word": "кровь", "start": 125.64, "end": 125.81}, {"word": "стирают", "start": 125.82, "end": 126.21}, {"word": "кошельки,", "start": 126.22, "end": 126.87}, {"word": "ради", "start": 126.88, "end": 127.29}, {"word": "лживой", "start": 127.3, "end": 127.73}, {"word": "правды", "start": 127.74, "end": 128.25}]}, {"time": 128.35, "text": "Время жатвы, время для особо жадных", "words": [{"word": "Время", "start": 128.35, "end": 128.8}, {"word": "жатвы,", "start": 128.81, "end": 128.85}, {"word": "время", "start": 128.86, "end": 128.96}, {"word": "для", "start": 129.78, "end": 130.02}, {"word": "особо", "start": 130.03, "end": 130.58}, {"word": "жадных", "start": 130.59, "end": 130.904}]}, {"time": 131.004, "text": "Время показать свою лояльность пионервожатым", "words": [{"word": "Время", "start": 131.004, "end": 133.641, "stretch": true}, {"word": "показать", "start": 133.651, "end": 133.751}, {"word": "свою", "start": 133.761, "end": 133.861}, {"word": "лояльность", "start": 133.871, "end": 133.971}, {"word": "пионервожатым", "start": 133.981, "end": 134.004}]}, {"time": 134.104, "text": "Зайцем шоколадным лосниться у их ног", "words": [{"word": "Зайцем", "start": 134.104, "end": 134.594}, {"word": "шоколадным", "start": 134.604, "end": 135.334}, {"word": "лосниться", "start": 135.344, "end": 135.754}, {"word": "у", "start": 135.934, "end": 136.114}, 