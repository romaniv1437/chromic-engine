{
  "name": "chromic-engine",
  "version": "1.0.5",
  "description": "Chromic Engine — High-Fidelity Music Player",
  "main": "electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/romaniv1437/draft-chromic-engine"
  },
  "scripts": {
    "install-all": "npm install && cd audio-visualizer && npm install",
    "server": "node index.js",
    "server:debug": "node index.js --debug",
    "viz-install": "cd audio-visualizer && npm install",
    "viz-build": "cd audio-visualizer && npm run build && npx esbuild ../public/visualizer/main.js --minify --format=esm --target=es2020 --legal-comments=none --outfile=../public/visualizer/main.js --allow-overwrite",
    "viz-dev": "cd audio-visualizer && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run viz-dev\"",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "build-all": "npm run viz-install && npm run viz-build && node scripts/build.mjs",
    "minify": "node scripts/build.mjs",
    "sanitize": "node scripts/sanitize.mjs",
    "sanitize:apply": "node scripts/sanitize.mjs --apply",
    "start": "npm run build-all && npm run server",
    "start:debug": "npm run build-all && npm run server:debug",
    "test": "node --test",
    "lyrics": "node fill-lyrics.js",
    "lyrics:force": "node fill-lyrics.js --force",
    "subs": "node subtitle-aligner/aligner.js --lang ukrainian --model gemma4:e4b",
    "subs:test": "node subtitle-aligner/aligner.js --lang ukrainian --model gemma4:e4b --test --chunk-size 10 --force",
    "subs:force": "node subtitle-aligner/aligner.js --lang ukrainian --model gemma4:e4b --force",
    "subs:enhanced": "node subtitle-aligner/aligner.js --lang ukrainian --model gemma4:e4b --enhanced --force",
    "subs:enhanced:test": "node subtitle-aligner/aligner.js --lang ukrainian --model gemma4:e4b --enhanced --test --chunk-size 10 --force",
    "scan": "npm run lyrics && npm run subs",
    "rebuild:node": "npm rebuild better-sqlite3 sharp",
    "rebuild:electron": "npx --yes @electron/rebuild --force --module-dir .",
    "electron": "npx --yes @electron/rebuild --force --module-dir . 2>/dev/null; electron --js-flags='--max-old-space-size=4096 --expose-gc' electron/main.js",
    "electron:debug": "npx --yes @electron/rebuild --force --module-dir . 2>/dev/null; electron --js-flags='--max-old-space-size=4096 --expose-gc' electron/main.js --chromic-debug",
    "electron:perf": "npx --yes @electron/rebuild --force --module-dir . 2>/dev/null; electron --js-flags='--max-old-space-size=4096 --expose-gc' electron/main.js --chromic-perf",
    "electron:dev": "electron electron/main.js",
    "electron:build": "electron-builder",
    "electron:build:mac": "electron-builder --mac",
    "electron:build:linux": "electron-builder --linux",
    "release": "electron-builder build --publish always",
    "postinstall": "electron-builder install-app-deps || true"
  },
  "author": {
    "name": "Illia Romaniv",
    "email": "romaniv1437@gmail.com"
  },
  "private": true,
  "build": {
    "appId": "com.romaniv1437.chromic-engine",
    "productName": "Chromic Engine",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "romaniv1437",
      "repo": "chromic-engine"
    },
    "files": [
      "index.js",
      "app-icon.png",
      "build/icon.png",
      "build/icon.ico",
      "public/**/*",
      "views/**/*",
      "electron/**/*",
      "media/tracks.db",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/sharp/**",
      "public/chromic-lyrics/vendor/*.ttf"
    ],
    "extraResources": [
      {
        "from": "scripts",
        "to": "scripts",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "data",
        "to": "data",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "lyrics-engine",
        "to": "lyrics-engine",
        "filter": [
          "aligner.py",
          "batch_align.py",
          "requirements.txt"
        ]
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "entitlements": null,
      "entitlementsInherit": null,
      "extendInfo": {
        "LSMinimumSystemVersion": "10.15.0"
      },
      "type": "distribution"
    },
    "afterSign": "scripts/afterSignHook.js",
    "dmg": {
      "icon": "build/icon.icns",
      "title": "Install Chromic Engine",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "executableName": "chromic-engine",
      "category": "Utility",
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "Chromic-Engine-Setup-${version}.${ext}",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "ejs": "^5.0.2",
    "electron-updater": "^6.3.9",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^1.4.5-lts.2",
    "music-metadata": "^11.12.3",
    "node-fetch": "^2.7.0",
    "sharp": "^0.34.5",
    "three": "^0.162.0",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@tauri-apps/cli": "^2.11.1",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.28.0",
    "nodemon": "^3.1.9"
  }
}
